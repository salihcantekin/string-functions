@using Microsoft.FluentUI.AspNetCore.Components
@inject IJSRuntime JSRuntime

@if (IsOpen)
{
    <div class="output-viewer-overlay" @onclick="Close">
        <div class="output-viewer-modal @(isFullscreen ? "fullscreen" : "")" @onclick:stopPropagation="true">
            <div class="output-viewer-header">
                <h3 class="output-viewer-title">@Title</h3>
                <div class="output-viewer-actions">
                    <FluentButton Appearance="Appearance.Lightweight" 
                                 IconStart="@(new Icons.Regular.Size20.ArrowMinimize())"
                                 @onclick="ToggleFullscreen"
                                 title="@(isFullscreen ? "Exit fullscreen" : "Enter fullscreen")">
                    </FluentButton>
                    <CopyButton Text="@Content" />
                    <FluentButton Appearance="Appearance.Lightweight" 
                                 IconStart="@(new Icons.Regular.Size20.Dismiss())"
                                 @onclick="Close"
                                 title="Close">
                    </FluentButton>
                </div>
            </div>
            <div class="output-viewer-content">
                <FluentTextArea Value="@Content" 
                               ReadOnly="true"
                               Resize="TextAreaResize.Vertical"
                               Class="viewer-textarea" />
            </div>
            @if (!string.IsNullOrEmpty(Footer))
            {
                <div class="output-viewer-footer">
                    @Footer
                </div>
            }
        </div>
    </div>
}

<style>
    .output-viewer-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.75);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        padding: 20px;
        animation: fadeIn 0.2s ease-in-out;
    }

    .output-viewer-modal {
        background: var(--bg-primary);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        width: 95%;
        max-width: 1400px;
        height: 85vh;
        max-height: 85vh;
        display: flex;
        flex-direction: column;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
        animation: slideUp 0.3s ease-out;
    }

    .output-viewer-modal.fullscreen {
        width: 100vw;
        max-width: 100vw;
        height: 100vh;
        max-height: 100vh;
        border-radius: 0;
        margin: 0;
    }

    .output-viewer-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 20px;
        border-bottom: 1px solid var(--border-color);
    }

    .output-viewer-title {
        font-size: 1.1rem;
        font-weight: 600;
        margin: 0;
        color: var(--text-primary);
    }

    .output-viewer-actions {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .output-viewer-content {
        flex: 1;
        padding: 16px;
        overflow: auto;
        display: flex;
        flex-direction: column;
    }

    .viewer-textarea {
        flex: 1 !important;
        min-height: 400px;
        font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
        font-size: 0.9rem;
    }

    .viewer-textarea::part(control) {
        height: 100% !important;
        min-height: 400px;
    }

    .output-viewer-footer {
        padding: 12px 20px;
        border-top: 1px solid var(--border-color);
        font-size: 0.85rem;
        color: var(--text-secondary);
        background: var(--bg-secondary);
        word-wrap: break-word;
        overflow-wrap: break-word;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    @@keyframes slideUp {
        from {
            transform: translateY(30px);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    @@media (max-width: 768px) {
        .output-viewer-modal {
            width: 95%;
            max-height: 95vh;
        }

        .output-viewer-overlay {
            padding: 10px;
        }
    }
</style>

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<bool> IsOpenChanged { get; set; }

    [Parameter]
    public string Title { get; set; } = "Output Viewer";

    [Parameter]
    public string Content { get; set; } = string.Empty;

    [Parameter]
    public string Footer { get; set; } = string.Empty;

    [Parameter]
    public EventCallback OnClose { get; set; }

    private bool isFullscreen = false;

    private async Task Close()
    {
        IsOpen = false;
        isFullscreen = false;
        await IsOpenChanged.InvokeAsync(IsOpen);
        await OnClose.InvokeAsync();
    }

    private void ToggleFullscreen()
    {
        isFullscreen = !isFullscreen;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (IsOpen)
        {
            await JSRuntime.InvokeVoidAsync("eval", "document.body.style.overflow = 'hidden'");
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("eval", "document.body.style.overflow = ''");
        }
    }
}
