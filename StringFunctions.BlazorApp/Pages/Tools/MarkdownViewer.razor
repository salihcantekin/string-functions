</style>

@code {
    private string markdownContent = @"# Welcome to Markdown Viewer! 👋

## Features
- **Real-time preview** as you type
- Syntax highlighting for code blocks
- Support for tables, lists, and more
- Export to HTML

## Example

Here's some *italic* and **bold** text.

### Code Example
```csharp
public class Example 
{
    public string Message { get; set; } = ""Hello World!"";
}
```

### Task List
- [x] Learn Markdown
- [ ] Build something awesome
- [ ] Share with others

> This is a blockquote

---

**Start editing** to see your changes!";

    private string viewMode = "split";
    private bool autoRefresh = true;
    private bool showLineNumbers = false;
    private bool cheatSheetExpanded = false;
    private bool templatesExpanded = false;
    private bool isMarkdownViewerOpen = false;
    private bool isPreviewViewerOpen = false;

    private void OnMarkdownChanged(ChangeEventArgs e)
    {
        markdownContent = e.Value?.ToString() ?? string.Empty;
        if (autoRefresh)
        {
            StateHasChanged();
        }
    }

    private string GetRenderedMarkdown()
    {
        if (string.IsNullOrWhiteSpace(markdownContent))
            return "<p style='color:#999;'>Enter Markdown to preview...</p>";

        return ConvertMarkdownToHtml(markdownContent);
    }

    private Task ExportMarkdownFile() => ExportMarkdown("md");
    private Task ExportHtmlFile() => ExportMarkdown("html");

    private string ConvertMarkdownToHtml(string markdown)
    {
        var html = markdown;

        // Headers
        html = System.Text.RegularExpressions.Regex.Replace(html, @"^######\s+(.+)$", "<h6>$1</h6>", System.Text.RegularExpressions.RegexOptions.Multiline);
        html = System.Text.RegularExpressions.Regex.Replace(html, @"^#####\s+(.+)$", "<h5>$1</h5>", System.Text.RegularExpressions.RegexOptions.Multiline);
        html = System.Text.RegularExpressions.Regex.Replace(html, @"^####\s+(.+)$", "<h4>$1</h4>", System.Text.RegularExpressions.RegexOptions.Multiline);
        html = System.Text.RegularExpressions.Regex.Replace(html, @"^###\s+(.+)$", "<h3>$1</h3>", System.Text.RegularExpressions.RegexOptions.Multiline);
        html = System.Text.RegularExpressions.Regex.Replace(html, @"^##\s+(.+)$", "<h2>$1</h2>", System.Text.RegularExpressions.RegexOptions.Multiline);
        html = System.Text.RegularExpressions.Regex.Replace(html, @"^#\s+(.+)$", "<h1>$1</h1>", System.Text.RegularExpressions.RegexOptions.Multiline);

        // Code blocks
        html = System.Text.RegularExpressions.Regex.Replace(html, @"```(\w+)?\n([\s\S]*?)```", "<pre><code>$2</code></pre>");

        // Bold
        html = System.Text.RegularExpressions.Regex.Replace(html, @"\*\*(.+?)\*\*", "<strong>$1</strong>");
        html = System.Text.RegularExpressions.Regex.Replace(html, @"__(.+?)__", "<strong>$1</strong>");

        // Italic
        html = System.Text.RegularExpressions.Regex.Replace(html, @"\*(.+?)\*", "<em>$1</em>");
        html = System.Text.RegularExpressions.Regex.Replace(html, @"_(.+?)_", "<em>$1</em>");

        // Strikethrough
        html = System.Text.RegularExpressions.Regex.Replace(html, @"~~(.+?)~~", "<del>$1</del>");

        // Inline code
        html = System.Text.RegularExpressions.Regex.Replace(html, @"`(.+?)`", "<code>$1</code>");

        // Links
        html = System.Text.RegularExpressions.Regex.Replace(html, @"\[([^\]]+)\]\(([^\)]+)\)", "<a href='$2'>$1</a>");

        // Images
        html = System.Text.RegularExpressions.Regex.Replace(html, @"!\[([^\]]*)\]\(([^\)]+)\)", "<img src='$2' alt='$1' />");

        // Blockquotes
        html = System.Text.RegularExpressions.Regex.Replace(html, @"^&gt;\s+(.+)$", "<blockquote>$1</blockquote>", System.Text.RegularExpressions.RegexOptions.Multiline);
        html = System.Text.RegularExpressions.Regex.Replace(html, @"^>\s+(.+)$", "<blockquote>$1</blockquote>", System.Text.RegularExpressions.RegexOptions.Multiline);

        // Horizontal rules
        html = System.Text.RegularExpressions.Regex.Replace(html, @"^---$", "<hr/>", System.Text.RegularExpressions.RegexOptions.Multiline);
        html = System.Text.RegularExpressions.Regex.Replace(html, @"^\*\*\*$", "<hr/>", System.Text.RegularExpressions.RegexOptions.Multiline);
        html = System.Text.RegularExpressions.Regex.Replace(html, @"^___$", "<hr/>", System.Text.RegularExpressions.RegexOptions.Multiline);

        // Unordered lists
        html = System.Text.RegularExpressions.Regex.Replace(html, @"^\s*[-*+]\s+(.+)$", "<li>$1</li>", System.Text.RegularExpressions.RegexOptions.Multiline);
        html = System.Text.RegularExpressions.Regex.Replace(html, @"(<li>.*?</li>)", "<ul>$1</ul>");

        // Task lists
        html = System.Text.RegularExpressions.Regex.Replace(html, @"<li>\s*\[\s*x\s*\]\s+(.+)</li>", "<li><input type='checkbox' checked disabled> $1</li>");
        html = System.Text.RegularExpressions.Regex.Replace(html, @"<li>\s*\[\s*\]\s+(.+)</li>", "<li><input type='checkbox' disabled> $1</li>");

        // Paragraphs
        var lines = html.Split('\n');
        var result = new System.Text.StringBuilder();
        var inParagraph = false;

        foreach (var line in lines)
        {
            var trimmed = line.Trim();
            if (string.IsNullOrWhiteSpace(trimmed))
            {
                if (inParagraph)
                {
                    result.Append("</p>");
                    inParagraph = false;
                }
                continue;
            }

            if (trimmed.StartsWith("<h") || trimmed.StartsWith("<ul") || trimmed.StartsWith("<pre") || 
                trimmed.StartsWith("<hr") || trimmed.StartsWith("<blockquote"))
            {
                if (inParagraph)
                {
                    result.Append("</p>");
                    inParagraph = false;
                }
                result.AppendLine(line);
            }
            else if (!trimmed.StartsWith("<li>"))
            {
                if (!inParagraph)
                {
                    result.Append("<p>");
                    inParagraph = true;
                }
                result.Append(line);
            }
            else
            {
                result.AppendLine(line);
            }
        }

        if (inParagraph)
        {
            result.Append("</p>");
        }

        return result.ToString();
    }

    private async Task CopyHtml()
    {
        // Copy HTML to clipboard
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", GetRenderedMarkdown());
    }

    private void OpenMarkdownFullscreen()
    {
        isMarkdownViewerOpen = true;
    }

    private void OpenPreviewFullscreen()
    {
        isPreviewViewerOpen = true;
    }

    private async Task ExportMarkdown(string format)
    {
        try
        {
            string content;
            string fileName;
            string mimeType;

            if (format == "md")
            {
                content = markdownContent;
                fileName = "document.md";
                mimeType = "text/markdown";
            }
            else // html
            {
                content = GetRenderedHtml();
                fileName = "document.html";
                mimeType = "text/html";
            }

            var escapedContent = content.Replace("\\", "\\\\").Replace("'", "\\'").Replace("\n", "\\n").Replace("\r", "");

            await JSRuntime.InvokeVoidAsync("eval", $@"
                const blob = new Blob(['{escapedContent}'], {{ type: '{mimeType}' }});
                const url = URL.createObjectURL(blob);
                const link = document.createElement('a');
                link.href = url;
                link.download = '{fileName}';
                link.click();
                URL.revokeObjectURL(url);
            ");
        }
        catch (Exception ex)
        {
            // Error handling - could show a message
            Console.WriteLine($"Export failed: {ex.Message}");
        }
    }

    private string GetRenderedHtml()
    {
        var fullHtml = $@"<!DOCTYPE html>
<html>
<head>
    <meta charset='UTF-8'>
    <meta name='viewport' content='width=device-width, initial-scale=1.0'>
    <title>Markdown Document</title>
    <style>
        body {{
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
            line-height: 1.6;
            color: #24292e;
            max-width: 900px;
            margin: 0 auto;
            padding: 20px;
        }}
        h1 {{ font-size: 2em; border-bottom: 1px solid #eee; padding-bottom: 0.3em; }}
        h2 {{ font-size: 1.5em; border-bottom: 1px solid #eee; padding-bottom: 0.3em; }}
        code {{
            padding: 2px 6px;
            background: #f6f8fa;
            border-radius: 3px;
            font-family: 'Consolas', monospace;
        }}
        pre {{
            padding: 16px;
            background: #f6f8fa;
            border-radius: 6px;
            overflow: auto;
        }}
        blockquote {{
            padding: 0 1em;
            color: #6a737d;
            border-left: 4px solid #dfe2e5;
        }}
        table {{
            border-collapse: collapse;
            width: 100%;
        }}
        table th, table td {{
            padding: 6px 13px;
            border: 1px solid #dfe2e5;
        }}
        table th {{
            background: #f6f8fa;
            font-weight: 600;
        }}
    </style>
</head>
<body>
    {ConvertMarkdownToHtml(markdownContent)}
</body>
</html>";
        return fullHtml;
    }

