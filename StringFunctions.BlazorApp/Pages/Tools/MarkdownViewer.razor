@page "/markdown-viewer"

<SeoHead Route="markdown-viewer" />

<PageTitle>Markdown Viewer</PageTitle>

<ToolPageLayout Title="Markdown Viewer" Description="Write and preview Markdown in real-time with syntax highlighting.">
    <OptionsContent>
        <div class="option-group">
            <span class="option-label">Mode:</span>
            <FluentSelect TOption="string" @bind-Value="@viewMode" Style="min-width: 160px;" @bind-Value:after="StateHasChanged">
                <FluentOption Value="preview">👁️ Preview</FluentOption>
                <FluentOption Value="split">📄 Split View</FluentOption>
                <FluentOption Value="markdown">📝 Markdown Only</FluentOption>
            </FluentSelect>
        </div>
        <div class="option-divider"></div>
        <FluentCheckbox @bind-Value="@autoRefresh" Label="Auto refresh" />
        <div class="option-divider"></div>
        <FluentCheckbox @bind-Value="@showLineNumbers" Label="Line numbers" @bind-Value:after="StateHasChanged" />
    </OptionsContent>
    <ChildContent>
        <div class="stats-bar">
            <span>@markdownContent.Length chars</span>
            <span>@(markdownContent.Split('\n').Length) lines</span>
            <span>~@((int)(markdownContent.Split(' ', StringSplitOptions.RemoveEmptyEntries).Length / 200.0)) min read</span>
        </div>

        <div class="markdown-viewer-layout @viewMode">
            @if (viewMode == "markdown" || viewMode == "split")
            {
                <div class="markdown-editor">
                    <div class="panel-header">
                        <span class="panel-title">📝 Markdown</span>
                        <div class="panel-actions">
                            <FluentButton Appearance="Appearance.Lightweight"
                                         IconStart="@(new Icons.Regular.Size20.ArrowExpand())"
                                         @onclick="OpenMarkdownFullscreen"
                                         title="Open in fullscreen">
                            </FluentButton>
                            <CopyButton Text="@markdownContent" />
                        </div>
                    </div>
                    <FluentTextArea @bind-Value="@markdownContent"
                                   Placeholder="# Enter Markdown here...&#10;&#10;Start typing to see live preview!"
                                   Resize="TextAreaResize.Vertical"
                                   @oninput="OnMarkdownChanged"
                                   Class="@($"code-editor {(showLineNumbers ? "show-line-numbers" : "")}")"
                                   Style="font-family: 'Consolas', 'Courier New', monospace;" />
                </div>
            }

            @if (viewMode == "preview" || viewMode == "split")
            {
                <div class="markdown-preview">
                    <div class="panel-header">
                        <span class="panel-title">👁️ Preview</span>
                        <div class="panel-actions">
                            <FluentButton Appearance="Appearance.Lightweight"
                                         IconStart="@(new Icons.Regular.Size20.ArrowExpand())"
                                         @onclick="OpenPreviewFullscreen"
                                         title="Open in fullscreen">
                            </FluentButton>
                            <FluentButton Appearance="Appearance.Lightweight"
                                         IconStart="@(new Icons.Regular.Size20.Document())"
                                         @onclick="ExportMarkdownFile"
                                         title="Save as Markdown">
                            </FluentButton>
                            <FluentButton Appearance="Appearance.Lightweight"
                                         IconStart="@(new Icons.Regular.Size20.DocumentArrowDown())"
                                         @onclick="ExportHtmlFile"
                                         title="Save as HTML">
                            </FluentButton>
                            <FluentButton Appearance="Appearance.Lightweight"
                                         IconStart="@(new Icons.Regular.Size20.Copy())"
                                         @onclick="CopyHtml"
                                         title="Copy HTML to clipboard">
                            </FluentButton>
                        </div>
                    </div>
                    <div class="preview-content markdown-body">
                        @((MarkupString)GetRenderedMarkdown())
                    </div>
                </div>
            }
        </div>

        <div style="margin-top: 20px;">
            <CollapsiblePanel Title="Markdown Cheat Sheet" @bind-IsExpanded="@cheatSheetExpanded">
            <div class="cheatsheet">
                <div class="cheat-section">
                    <h4>Headers</h4>
                    <code># H1<br/## H2<br/>### H3</code>
                </div>
                <div class="cheat-section">
                    <h4>Emphasis</h4>
                    <code>*italic* or _italic_<br/>**bold** or __bold__<br/>~~strikethrough~~</code>
                </div>
                <div class="cheat-section">
                    <h4>Lists</h4>
                    <code>- Item 1<br/>- Item 2<br/>  - Nested<br/><br/>1. First<br/>2. Second</code>
                </div>
                <div class="cheat-section">
                    <h4>Links & Images</h4>
                    <code>[Link text](url)<br/>![Alt text](image.jpg)</code>
                </div>
                <div class="cheat-section">
                    <h4>Code</h4>
                    <code>`inline code`<br/><br/>```language<br/>code block<br/>```</code>
                </div>
                <div class="cheat-section">
                    <h4>Blockquotes</h4>
                    <code>&gt; Quote<br/>&gt; Continues</code>
                </div>
                <div class="cheat-section">
                    <h4>Tables</h4>
                    <code>| Col1 | Col2 |<br/>|------|------|<br/>| A    | B    |</code>
                </div>
                <div class="cheat-section">
                    <h4>Horizontal Rule</h4>
                    <code>---<br/>***<br/>___</code>
                </div>
            </div>
        </CollapsiblePanel>

        <div style="margin-top: 12px;">
            <CollapsiblePanel Title="Markdown Templates" @bind-IsExpanded="@templatesExpanded">
            <div class="templates-grid">
                <FluentButton Appearance="Appearance.Outline" @onclick="@(() => LoadTemplate("readme"))">
                    📄 README
                </FluentButton>
                <FluentButton Appearance="Appearance.Outline" @onclick="@(() => LoadTemplate("blog"))">
                    📝 Blog Post
                </FluentButton>
                <FluentButton Appearance="Appearance.Outline" @onclick="@(() => LoadTemplate("docs"))">
                    📚 Documentation
                </FluentButton>
                <FluentButton Appearance="Appearance.Outline" @onclick="@(() => LoadTemplate("notes"))">
                    📓 Meeting Notes
                </FluentButton>
                <FluentButton Appearance="Appearance.Outline" @onclick="@(() => LoadTemplate("todo"))">
                    ✅ Todo List
                </FluentButton>
                <FluentButton Appearance="Appearance.Outline" @onclick="@(() => LoadTemplate("changelog"))">
                    📋 Changelog
                </FluentButton>
            </div>
        </CollapsiblePanel>
        </div>
        </div>
    </ChildContent>
</ToolPageLayout>

<OutputViewer @bind-IsOpen="@isMarkdownViewerOpen"
             Title="Markdown Source"
             Content="@markdownContent"
             ContentChanged="@((value) => { markdownContent = value; StateHasChanged(); })"
             IsEditable="true"
             Footer="@($"{markdownContent.Length} chars, {markdownContent.Split('\n').Length} lines, ~{(int)(markdownContent.Split(' ', StringSplitOptions.RemoveEmptyEntries).Length / 200.0)} min read")" />

<OutputViewer @bind-IsOpen="@isPreviewViewerOpen"
             Title="Markdown Preview (Rendered)"
             Footer="Rendered HTML output"
             ShowCopyButton="false">
    <div class="markdown-body" style="padding: 20px; height: 100%; overflow-y: auto; background: white;">
        @((MarkupString)GetRenderedMarkdown())
    </div>
</OutputViewer>

<style>
