        margin: 0 0 16px 0;
    }
    
    .markdown-body ul, .markdown-body ol {
        padding-left: 2em;
        margin-bottom: 16px;
    }
    
    .markdown-body table {
        border-collapse: collapse;
        width: 100%;
        margin-bottom: 16px;
    }
    
    .markdown-body table th,
    .markdown-body table td {
        padding: 6px 13px;
        border: 1px solid #dfe2e5;
    }
    
    .markdown-body table th {
        background: #f6f8fa;
        font-weight: 600;
    }
    
    .markdown-body hr {
        height: 2px;
        padding: 0;
        margin: 24px 0;
