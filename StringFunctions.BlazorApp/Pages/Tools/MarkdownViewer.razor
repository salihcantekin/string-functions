        padding: 20px;
        border: 1px solid var(--border-color);
        border-radius: 4px;
        overflow-y: auto;
        background: white;
        height: 100%;
        max-height: 100%;
    }

    .markdown-body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
        line-height: 1.6;
        color: #24292e;
    }

